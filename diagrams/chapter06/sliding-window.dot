digraph SlidingWindow {
    rankdir=LR;
    graph [dpi=200, bgcolor="white", pad="0.2"];
    node [shape=box, style="rounded,filled", fillcolor="#F7FAFF", color="#4A6FA5", fontname="Microsoft YaHei", fontsize=11];
    edge [color="#4A6FA5", penwidth=1.2, arrowsize=0.8];

    input [label="句子视频帧序列\nFrame 0 ... Frame n-1", fillcolor="#EAF2FF"];

    win1 [label="窗口 1\n起点 0\n长度 20 帧"];
    win2 [label="窗口 2\n起点 2\n长度 20 帧"];
    win3 [label="窗口 3\n起点 4\n长度 20 帧"];
    more [label="...\n按步长继续滑动", fillcolor="#FFF7E6"];
    last [label="末尾补充窗口\n覆盖视频尾部", fillcolor="#FFEFEF"];

    feat1 [label="20 × 232\n窗口特征矩阵"];
    feat2 [label="20 × 232\n窗口特征矩阵"];
    feat3 [label="20 × 232\n窗口特征矩阵"];
    featL [label="20 × 232\n窗口特征矩阵"];

    batch [label="批量推理输入\nNw × 20 × 232", fillcolor="#E8FFF1"];
    model [label="词级分类模型\n批量推理", fillcolor="#E8FFF1"];
    result [label="逐窗口预测结果\n词段合并与过滤", fillcolor="#E8FFF1"];

    input -> win1;
    input -> win2;
    input -> win3;
    input -> more;
    input -> last;

    win1 -> feat1;
    win2 -> feat2;
    win3 -> feat3;
    last -> featL;

    feat1 -> batch;
    feat2 -> batch;
    feat3 -> batch;
    featL -> batch;

    batch -> model -> result;
}