digraph G {
  graph [
    rankdir=TB,
    splines=ortho,
    nodesep=0.38,
    ranksep=0.45,
    pad=0.12,
    dpi=280,
    bgcolor="white"
  ];

  node [
    shape=box,
    style="rounded",
    color="black",
    penwidth=1.2,
    fontname="Microsoft YaHei",
    fontsize=16,
    margin="0.18,0.12"
  ];

  edge [
    color="black",
    arrowsize=0.75,
    penwidth=1.1,
    fontname="Microsoft YaHei",
    fontsize=11
  ];

  list [
    label="样本清单\n视频路径 / Gloss 标签"
  ];

  decode [
    label="视频读取与解码\nOpenCV 帧序列"
  ];

  detect [
    label="关键点检测\nHolistic 结果"
  ];

  window [
    label="动作窗口定位\nhand_flags + padding"
  ];

  sample [
    label="重采样 20 帧\n统一时间长度"
  ];

  feature [
    label="构造 plus 特征\n20 × 232"
  ];

  dataset [
    label="输出数据集\nX.npy / y.npy\nlabels.json / sample_index.csv"
  ];

  { rank=same; list; decode; detect; }
  { rank=same; feature; sample; window; }

  list -> decode -> detect;
  detect -> window;

  feature -> sample -> window [style=invis, weight=100];
  window -> sample [constraint=false];
  sample -> feature [constraint=false];
  feature -> dataset;
}
