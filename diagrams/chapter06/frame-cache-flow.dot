digraph G {
  graph [
    rankdir=TB,
    splines=ortho,
    nodesep=0.36,
    ranksep=0.42,
    pad=0.12,
    dpi=280,
    bgcolor="white"
  ];

  node [
    shape=box,
    style="rounded",
    color="black",
    penwidth=1.2,
    fontname="Microsoft YaHei",
    fontsize=16,
    margin="0.18,0.12"
  ];

  edge [
    color="black",
    arrowsize=0.75,
    penwidth=1.1,
    fontname="Microsoft YaHei",
    fontsize=12
  ];

  upload [
    label="上传视频\n文件校验"
  ];

  save [
    label="保存文件\n创建临时目录"
  ];

  read [
    label="读取视频\n元信息与帧序列"
  ];

  detect [
    label="逐帧检测\nHolistic 关键点"
  ];

  cache [
    label="缓存结果\nframes / results"
  ];

  reuse [
    label="统计覆盖率\n供窗口复用"
  ];

  { rank=same; upload; save; read; }
  { rank=same; reuse; cache; detect; }

  upload -> save -> read;
  read -> detect;
  reuse -> cache -> detect [style=invis, weight=100];
  detect -> cache [constraint=false];
  cache -> reuse [constraint=false];
}
