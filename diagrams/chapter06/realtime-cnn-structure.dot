digraph G {
  graph [
    rankdir=TB,
    splines=ortho,
    nodesep=0.35,
    ranksep=0.42,
    bgcolor="white",
    pad=0.18,
    dpi=220
  ];

  node [
    shape=box,
    style="rounded",
    color="black",
    penwidth=1.2,
    fontname="Microsoft YaHei",
    fontsize=14,
    margin="0.18,0.10"
  ];

  edge [
    color="black",
    arrowsize=0.75,
    penwidth=1.2,
    fontname="Microsoft YaHei",
    fontsize=11
  ];

  input [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>输入层</B></TD></TR>
        <TR><TD>30 × 166 时序特征</TD></TR>
      </TABLE>
    >
  ];

  conv1 [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>一维卷积层 Conv1D</B></TD></TR>
        <TR><TD>filters = 96, kernel size = 3</TD></TR>
        <TR><TD>activation = ReLU</TD></TR>
      </TABLE>
    >
  ];

  pool1 [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>最大池化层 MaxPooling1D</B></TD></TR>
        <TR><TD>pool size = 2</TD></TR>
      </TABLE>
    >
  ];

  conv2 [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>一维卷积层 Conv1D</B></TD></TR>
        <TR><TD>filters = 160, kernel size = 3</TD></TR>
        <TR><TD>activation = ReLU</TD></TR>
      </TABLE>
    >
  ];

  gap [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>全局平均池化层</B></TD></TR>
        <TR><TD>GlobalAveragePooling1D</TD></TR>
      </TABLE>
    >
  ];

  dense1 [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>全连接层 Dense</B></TD></TR>
        <TR><TD>units = 96, activation = ReLU</TD></TR>
      </TABLE>
    >
  ];

  drop [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>Dropout 层</B></TD></TR>
        <TR><TD>rate = 0.3</TD></TR>
      </TABLE>
    >
  ];

  output [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>输出层 Dense</B></TD></TR>
        <TR><TD>units = num_classes</TD></TR>
        <TR><TD>activation = Softmax</TD></TR>
      </TABLE>
    >
  ];

  input -> conv1;
  conv1 -> pool1;
  pool1 -> conv2;
  conv2 -> gap;
  gap -> dense1;
  dense1 -> drop;
  drop -> output;
}